    "@tabler/icons-svelte": "^3.34.1",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "diff": "^8.0.2",
    "dompurify": "^3.2.6",
    "eventsource": "^4.0.0",
    "libsodium-wrappers": "0.7.15",
    "lucide-svelte": "^0.544.0",
    "marked": "^15.0.8",
    "monaco-editor": "^0.52.2",
    "motion": "^12.23.12",
    "posthog-js": "^1.266.3",
    "svelte-dnd-action": "^0.9.61",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.3.1",
