    "@sveltejs/vite-plugin-svelte": "^6.1.3",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.3.3",
    "daisyui": "^5.5.19",
    "eslint": "^9.33.0",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.3.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.38.0",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^4.1.13",
