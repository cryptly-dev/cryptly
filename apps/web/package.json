{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 9090 --strictPort",
    "start": "vite dev --host 127.0.0.1 --port 9090 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 9090 --strictPort",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "deploy:staging": "pnpm build && wrangler deploy --env staging",
    "deploy:production": "pnpm build && wrangler deploy --env production"
  },
  "dependencies": {
    "@fontsource-variable/funnel-display": "^5.2.8",
    "@packages/backend-sdk": "workspace:*",
    "libsodium-wrappers": "0.7.15",
    "lucide-svelte": "^0.544.0",
    "posthog-js": "^1.266.3",
    "svelte-sonner": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@sveltejs/adapter-cloudflare": "^7.0.3",
    "@sveltejs/kit": "^2.39.1",
    "@sveltejs/vite-plugin-svelte": "^6.1.3",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.3.3",
    "daisyui": "^5.0.43",
    "eslint": "^9.33.0",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.38.0",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "wrangler": "^4.33.1"
  }
}
